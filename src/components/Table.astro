        font-size: 0.9rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.18);
        white-space: nowrap;
    }
    .sample-table th {
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }
    .sample-table tbody tr:last-child td {
        border-bottom: none;
    }
    .sample-table .cell-strong {
        font-weight: 600;
