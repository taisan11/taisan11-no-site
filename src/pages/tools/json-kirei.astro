---
import Layout from "../../layouts/layout.astro";
import A from "../../components/A.astro";
---

<Layout title="taisan11のサイト">
    <div class="nue">
      <A href="/tools">← 戻る</A><br/>
      <div>
          <h2>Base 64 エンコード/デコード</h2>
          <div>
              <textarea id="mae" name="mae" rows="8" cols="100"></textarea>
              <div>
                  <button id="kirei">綺麗にする↓</button>
                  <input type="checkbox" id="urldecode" name="urldecode" checked />
                  <label for="urldecode">URLデコードする</label>
              </div>
              <textarea id="ato" name="ato" rows="30" cols="100"></textarea>
          </div>
      </div>
  </div>
</Layout>

<script>
const mae = document.getElementById("mae") as HTMLTextAreaElement
const ato = document.getElementById("ato") as HTMLTextAreaElement
const kirei = document.getElementById("kirei") as HTMLButtonElement
const urldecode = document.getElementById("urldecode") as HTMLInputElement

function decodeObject(obj) {
  if (typeof obj === "string") {
    try {
      return decodeURIComponent(obj)
    } catch {
      return obj
    }
  }

  if (Array.isArray(obj)) {
    return obj.map(decodeObject)
  }

  if (obj && typeof obj === "object") {
    return Object.fromEntries(
      Object.entries(obj).map(([k, v]) => [k, decodeObject(v)])
    )
  }

  return obj
}

kirei!.onclick = () => {
  try {
    let obj = JSON.parse(mae.value)

    if (urldecode.checked) {
      obj = decodeObject(obj)
    }

    ato.value = JSON.stringify(obj, null, 2)
  } catch (e) {
    console.error(e)
  }
}
</script>

<style is:global>
    textarea {
        font-size:1rem;
        max-width: 85vw;
    }
    /*最初の二桁*/
    .twoketa {
        color:#81E4DA;
        font-size:3rem
    }
    .syosu {
        font-size:1.2rem
    }
    #nokori {
        font-size:2rem
    }
    h1 {
        text-align: center
    }
    @media (orientation: landscape) {
        /*textarea {
            font-size:1.5rem
        }*/
        .nue {
            width: 50vw;
            margin: 0 auto;
        }
    }
</style>
