---
import Layout from "../../layouts/layout.astro";
---

<Layout title="東方紅魔郷 カウントダウン">
  <main>
    <section class="countdown-container">
      <h1>東方紅魔郷 New Classic発売まで</h1>
      <p class="release-info">発売日：2026年9月10日</p>

      <div class="countdown" id="countdown">
        <div class="countdown-item">
          <span class="countdown-value" id="months">0</span>
          <span class="countdown-label">月</span>
        </div>
        <div class="countdown-item" id="kyo">
          <span class="countdown-value" id="days">0</span>
          <span class="countdown-label">日</span>
        </div>
        <div class="countdown-item">
          <span class="countdown-value" id="hours">0</span>
          <span class="countdown-label">時</span>
        </div>
        <div class="countdown-item">
          <span class="countdown-value" id="minutes">0</span>
          <span class="countdown-label">分</span>
        </div>
        <div class="countdown-item">
          <span class="countdown-value" id="seconds">0</span>
          <span class="countdown-label">秒</span>
        </div>
      </div>

      <p class="countdown-status" id="status"></p>
    </section>
  </main>
</Layout>

<script>
  const releaseDate = new Date('2026-09-10T00:00:00')
  const countdownEl = document.getElementById('countdown')!;
  const statusEl = document.getElementById('status')!;

  const monthsEl = document.getElementById('months')!;
  const daysEl = document.getElementById('days')!;
  const hoursEl = document.getElementById('hours')!;
  const minutesEl = document.getElementById('minutes')!;
  const secondsEl = document.getElementById('seconds')!;
  const kyoEl = document.getElementById('kyo')!;

  let monthsRemoved = false;

  function getDateDiff(from:Date, to:Date) {
    let months = 0;

    // カレンダー基準で月を加算
    while (true) {
      const next = new Date(from);

      const originalDay = next.getDate();

      next.setMonth(next.getMonth() + 1);

      // 1/31 → 3/2 のような補正を防止
      if (next.getDate() !== originalDay) {
        next.setDate(0);
      }

      if (next <= to) {
        from = next;
        months++;
      } else {
        break;
      }
    }

    //@ts-expect-error TypeScript側が悪い
    let remaining = to - from;

    const days = Math.floor(remaining / 86400000);
    remaining %= 86400000;

    const hours = Math.floor(remaining / 3600000);
    remaining %= 3600000;

    const minutes = Math.floor(remaining / 60000);
    remaining %= 60000;

    const seconds = Math.floor(remaining / 1000);

    return {
      months,
      days,
      hours,
      minutes,
      seconds
    };
  }

  function updateCountdown() {
    const now = new Date();

    if (releaseDate <= now) {
      countdownEl.innerHTML =
        '<p style="font-size: 24px; text-align: center; color: #e74c3c;">発売開始！</p>';

      statusEl.textContent =
        '東方紅魔郷NewClassic 好評発売中!!';

      return;
    }

    const diff = getDateDiff(now, releaseDate);

    // 月
    if (diff.months === 0) {
      if (!monthsRemoved) {
        monthsEl.outerHTML = '';
        monthsRemoved = true;
      }
    } else {
      monthsEl.textContent = String(diff.months);
    }

    // 今日判定
    if (diff.months === 0 && diff.days === 0) {
        kyoEl.textContent = '今日';
    } else {
      daysEl.textContent = String(diff.days);
    }

      hoursEl.textContent = String(diff.hours);

      minutesEl.textContent = String(diff.minutes);

      secondsEl.textContent = String(diff.seconds);
  }

  updateCountdown();
  setInterval(updateCountdown, 500);
</script>
<!-- 紅魔郷のサイトから引っ張ってきた!! -->
<style>
:root {
  --color-dark-red: #770818;
  --color-black-red: #390b1b;
  --color-ash-red: #9c5d5d;
  --color-neutral-red: #ca1a1f;
  --color-gold: #c5ae86;
  --color-light-gray: #eadada;
  --color-white: #ffffff;
  --color-switch: #e60012;
  --color-playstation: #00439c;
  --color-steam: #2881a7;
  --color-text: #390b1b;
  --color-bg: #fff8f5;
  --font-family-base: "YakuHanMP", "Shippori Mincho B1", serif;
  --font-family-display: "Chonburi", serif;
  --font-size-xs: 1.2rem;
  --font-size-s: 1.4rem;
  --font-size-m: 1.6rem;
  --font-size-l: 1.8rem;
  --font-size-xl: 2rem;
  --font-size-xxl: 2.4rem;
  --font-size-xxxl: 3.2rem;
  --font-size-xxxxl: 4.8rem;
  --font-size-xxxxxl: 6.4rem;
  --spacing-section: 10rem;
  --spacing-inner: 4rem;
  --content-max-width: 1214px
}
  main {
      background-color: --color-bg;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 2rem;
  }

  .countdown-container {
    text-align: center;
    padding: 1rem;
    max-width: 80vw;
    color: white;
  }

  h1 {
    font-size: 2.5rem;
    margin: 0 0 0.5rem 0;
    font-weight: 700;
  }

  .release-info {
    font-size: 1.1rem;
    margin: 0 0 2rem 0;
    opacity: 0.9;
  }

  .countdown {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(0, 1fr));
    gap: 0;
    margin: 0;
  }

  .countdown-item {
    padding: 1rem 0;
  }

  .countdown-value {
    /*display: block;*/
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .countdown-label {
    /*display: block;*/
    font-size: 1rem;
    opacity: 0.85;
    font-weight: 600;
  }

  .countdown-status {
    font-size: 1.3rem;
    margin-top: 2rem;
    font-weight: 600;
  }

  @media (orientation: portrait) {
      main {
          padding:0
      }

    .countdown-container {
      max-width: 100vw;
      padding: 1rem;
    }

    h1 {
      font-size: 1.5rem;
    }

    .countdown {
      gap: 0.75rem;
    }

    .countdown-value {
      font-size: 2rem;
    }
  }
</style>
