---
import Layout from "../../layouts/layout.astro";
import A from "../../components/A.astro";
---

<Layout title="taisan11のサイト">
    <div class="nue">
      <A href="/tools">← 戻る</A><br/>
      <div class="c">
          <h2>QRCode生成機</h2>
          <label class="text-input">
              内容
              <input type="text" placeholder="URLや文字を入力" id="text" />
          </label>

          <div class="qr-controls">
              <label>
                  通常ドットの形
                  <select name="pattern" id="pattern">
                      <option value="sikaku">四角</option>
                      <option value="maru">丸</option>
                  </select>
              </label>
              <label>
                  角パターンの形（3か所）
                  <select id="finder-pattern">
                      <option value="sikaku">四角</option>
                      <option value="maru">丸</option>
                  </select>
              </label>
              <label>
                  誤り訂正
                  <select id="ecc">
                      <option value="low">低 (7%)</option>
                      <option value="medium" selected>中 (15%)</option>
                      <option value="quartile">高 (25%)</option>
                      <option value="high">最高 (30%)</option>
                  </select>
              </label>
              <label class="range-label">
                  <span>画像サイズ <output id="size-value">512</output>px</span>
                  <input type="range" id="size" min="128" max="2048" step="16" value="1024" />
              </label>
              <label>
                  <span>画像サイズを直接入力</span>
                  <input type="number" id="size-number" min="128" max="2048" step="16" value="1024" />
              </label>
              <label class="range-label">
                  <span>余白 <output id="border-value">4</output>セル</span>
                  <input type="range" id="border" min="1" max="10" step="1" value="4" />
              </label>
              <label class="range-label">
                  <span>セル間隔（0%で隙間なし） <output id="gap-value">0</output>%</span>
                  <input type="range" id="gap" min="0" max="30" step="1" value="0" />
              </label>
              <label class="range-label">
                  <span>丸み <output id="roundness-value">100</output>%</span>
                  <input type="range" id="roundness" min="0" max="100" step="1" value="100" />
              </label>
              <div class="color-inputs">
                  <label>背景色 <input type="color" id="background" value="#ffffff" /></label>
                  <label class="file-input">
                      背景画像
                      <input type="file" id="background-image" accept="image/*" />
                  </label>
                  <button type="button" id="clear-background-image">背景画像を解除</button>
              </div>
          </div>

          <button id="GO">生成・更新</button>
          <p id="message" role="status" aria-live="polite"></p>
          <div id="qr"></div>
      </div>
  </div>
</Layout>

<script>
import {encodeQR} from "qr"

const img = document.getElementById("qr") as HTMLDivElement
const textInput = document.getElementById("text") as HTMLInputElement
const patternInput = document.getElementById("pattern") as unknown as HTMLSelectElement
const finderPatternInput = document.getElementById("finder-pattern") as HTMLSelectElement
const eccInput = document.getElementById("ecc") as unknown as HTMLSelectElement
const sizeInput = document.getElementById("size") as HTMLInputElement
const sizeNumberInput = document.getElementById("size-number") as HTMLInputElement
const borderInput = document.getElementById("border") as HTMLInputElement
const gapInput = document.getElementById("gap") as HTMLInputElement
const roundnessInput = document.getElementById("roundness") as HTMLInputElement
const backgroundInput = document.getElementById("background") as HTMLInputElement
const backgroundImageInput = document.getElementById("background-image") as HTMLInputElement
const clearBackgroundImageButton = document.getElementById("clear-background-image") as HTMLButtonElement
const message = document.getElementById("message") as HTMLParagraphElement
let backgroundImage: HTMLImageElement | null = null
let backgroundImageUrl: string | null = null

type ErrorCorrection = "low" | "medium" | "quartile" | "high"

function drawRoundedCell(
  ctx: CanvasRenderingContext2D,
  x: number,
  y: number,
  size: number,
  radius: number,
  overlap = 0,
) {
  const drawX = x - overlap
  const drawY = y - overlap
  const drawSize = size + overlap * 2
  const drawRadius = Math.min(drawSize / 2, radius + overlap)

  if (drawRadius <= 0) {
    ctx.fillRect(x, y, size, size)
    return
  }

  const right = drawX + drawSize
  const bottom = drawY + drawSize
  ctx.beginPath()
  ctx.moveTo(drawX + drawRadius, drawY)
  ctx.arcTo(right, drawY, right, bottom, drawRadius)
  ctx.arcTo(right, bottom, drawX, bottom, drawRadius)
  ctx.arcTo(drawX, bottom, drawX, drawY, drawRadius)
  ctx.arcTo(drawX, drawY, right, drawY, drawRadius)
  ctx.closePath()
  ctx.fill()
}

function isFinderModule(x: number, y: number, moduleCount: number, border: number) {
  const qrSize = moduleCount - border * 2
  const qrX = x - border
  const qrY = y - border
  const finderSize = 7
  const inFinder = (left: number, top: number) =>
    qrX >= left && qrX < left + finderSize && qrY >= top && qrY < top + finderSize

  return (
    inFinder(0, 0) ||
    inFinder(qrSize - finderSize, 0) ||
    inFinder(0, qrSize - finderSize)
  )
}

function drawBackground(ctx: CanvasRenderingContext2D, imageSize: number) {
  ctx.fillStyle = backgroundInput.value
  ctx.fillRect(0, 0, imageSize, imageSize)
  if (!backgroundImage) return

  const scale = Math.max(
    imageSize / backgroundImage.naturalWidth,
    imageSize / backgroundImage.naturalHeight,
  )
  const width = backgroundImage.naturalWidth * scale
  const height = backgroundImage.naturalHeight * scale
  ctx.drawImage(backgroundImage, (imageSize - width) / 2, (imageSize - height) / 2, width, height)
}

function getDotColor(
  backgroundPixels: Uint8ClampedArray,
  imageSize: number,
  x: number,
  y: number,
) {
  const sampleX = Math.min(imageSize - 1, Math.max(0, Math.floor(x)))
  const sampleY = Math.min(imageSize - 1, Math.max(0, Math.floor(y)))
  const pixelIndex = (sampleY * imageSize + sampleX) * 4
  const brightness =
    backgroundPixels[pixelIndex] * 0.299 +
    backgroundPixels[pixelIndex + 1] * 0.587 +
    backgroundPixels[pixelIndex + 2] * 0.114

  return brightness >= 160 ? "#000000" : "#ffffff"
}

function updateLabels() {
  document.getElementById("size-value")!.textContent = sizeInput.value
  document.getElementById("border-value")!.textContent = borderInput.value
  document.getElementById("gap-value")!.textContent = gapInput.value
  document.getElementById("roundness-value")!.textContent = roundnessInput.value
  roundnessInput.disabled = patternInput.value !== "maru" && finderPatternInput.value !== "maru"
}

function setSize(value: string) {
  const size = Math.min(2048, Math.max(128, Number(value) || 512))
  sizeInput.value = String(size)
  sizeNumberInput.value = String(size)
  updateLabels()
}

function renderQR() {
  const text = textInput.value
  if (!text) {
    img.innerHTML = ""
    message.textContent = "内容を入力してください"
    return
  }

  try {
    const pattern = patternInput.value
    const finderPattern = finderPatternInput.value
    const imageSize = Number(sizeInput.value)
    const border = Number(borderInput.value)
    const gap = Number(gapInput.value) / 100
    const roundness = Number(roundnessInput.value) / 100
    const qr = encodeQR(text, "raw", {
      ecc: eccInput.value as ErrorCorrection,
      border,
    })
    const moduleCount = qr.length
    const moduleSize = imageSize / moduleCount
    const cellSize = moduleSize * (1 - gap)
    const inset = (moduleSize - cellSize) / 2
    const canvas = document.createElement("canvas")
    canvas.width = imageSize
    canvas.height = imageSize
    canvas.setAttribute("aria-label", "生成されたQRコード")
    const ctx = canvas.getContext("2d")!
    drawBackground(ctx, imageSize)
    const backgroundPixels = ctx.getImageData(0, 0, imageSize, imageSize).data

    for (let y = 0; y < moduleCount; y++) {
      for (let x = 0; x < moduleCount; x++) {
        if (!qr[y][x]) continue
        const cellX = x * moduleSize + inset
        const cellY = y * moduleSize + inset
        const shape = isFinderModule(x, y, moduleCount, border) ? finderPattern : pattern
        ctx.fillStyle = getDotColor(
          backgroundPixels,
          imageSize,
          (x + 0.5) * moduleSize,
          (y + 0.5) * moduleSize,
        )
        if (shape === "maru") {
          const overlap = gap === 0 && roundness === 1 ? Math.min(0.75, moduleSize * 0.08) : 0
          drawRoundedCell(ctx, cellX, cellY, cellSize, (cellSize / 2) * roundness, overlap)
        } else {
          ctx.fillRect(cellX, cellY, cellSize, cellSize)
        }
      }
    }

    img.innerHTML = ""
    img.appendChild(canvas)
    message.textContent = `${imageSize}×${imageSize}px で生成しました`
  } catch (error) {
    img.innerHTML = ""
    message.textContent = error instanceof Error ? error.message : "QRコードを生成できませんでした"
  }
}

document.getElementById("GO")!.addEventListener("click", renderQR)
sizeInput.addEventListener("input", () => {
  setSize(sizeInput.value)
  if (textInput.value) renderQR()
})
sizeNumberInput.addEventListener("change", () => {
  setSize(sizeNumberInput.value)
  if (textInput.value) renderQR()
})

const controls = [patternInput, finderPatternInput, eccInput, borderInput, gapInput, roundnessInput, backgroundInput]
controls.forEach((control) => {
  control.addEventListener("input", () => {
    updateLabels()
    if (textInput.value) renderQR()
  })
  control.addEventListener("change", () => {
    updateLabels()
    if (textInput.value) renderQR()
  })
})
backgroundImageInput.addEventListener("change", () => {
  const file = backgroundImageInput.files?.[0]
  if (!file) return

  if (backgroundImageUrl) URL.revokeObjectURL(backgroundImageUrl)
  const imageUrl = URL.createObjectURL(file)
  backgroundImageUrl = imageUrl
  const image = new Image()
  image.onload = () => {
    if (backgroundImageUrl !== imageUrl) return
    backgroundImage = image
    URL.revokeObjectURL(imageUrl)
    backgroundImageUrl = null
    if (textInput.value) renderQR()
  }
  image.onerror = () => {
    if (backgroundImageUrl !== imageUrl) return
    backgroundImage = null
    URL.revokeObjectURL(imageUrl)
    backgroundImageUrl = null
    message.textContent = "背景画像を読み込めませんでした"
  }
  image.src = imageUrl
})
clearBackgroundImageButton.addEventListener("click", () => {
  if (backgroundImageUrl) URL.revokeObjectURL(backgroundImageUrl)
  backgroundImageUrl = null
  backgroundImage = null
  backgroundImageInput.value = ""
  if (textInput.value) renderQR()
})
textInput.addEventListener("keydown", (event) => {
  if (event.key === "Enter") renderQR()
})
updateLabels()
</script>

<style is:global>
    .nue {}
    .text-input {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        margin-bottom: 16px;
    }
    .text-input input {
        min-width: min(420px, 70vw);
    }
    .qr-controls {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
        max-width: 560px;
        margin: 0 auto 16px;
        text-align: left;
    }
    .qr-controls label,
    .color-inputs label {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }
    .qr-controls select,
    .qr-controls input[type="number"] {
        width: 100%;
        box-sizing: border-box;
    }
    .range-label span {
        display: flex;
        justify-content: space-between;
    }
    .range-label input {
        width: 100%;
    }
    .color-inputs {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
        grid-column: 1 / -1;
    }
    .color-inputs input {
        width: 100%;
        min-height: 32px;
        box-sizing: border-box;
    }
    .color-inputs button {
        align-self: end;
        min-height: 32px;
    }
    #message {
        min-height: 1.5em;
        margin: 12px 0;
    }
    #qr {
        background-color: white;
        width: min(90vw, 2048px);
        max-width: 100%;
        display: flex;
        justify-content: center; /* 横中央 */
        align-items: center;     /* 縦中央 */
        margin: 0 auto;
    }
    #qr canvas {
        display: block;
        max-width: 100%;
        height: auto;
    }
    .c {
        text-align: center;
    }
    @media (orientation: landscape) {
        .nue {
            width: 50vw;
            margin: 0 auto;
        }
        #qr {
            width: 80%;
        }
    }
    @media (max-width: 600px) {
        .text-input {
            align-items: stretch;
            flex-direction: column;
        }
        .text-input input {
            min-width: 0;
        }
        .qr-controls {
            grid-template-columns: 1fr;
        }
        .color-inputs {
            grid-column: auto;
        }
    }
</style>
