---
import Layout from "../../layouts/layout.astro";
import A from "../../components/A.astro";
---

<Layout title="簡易メモ帳">
    <div class="nue">
      <A href="/tools">← 戻る</A><br/>
      <main>
          <h2>簡易メモ帳</h2>
          <div id="bankBar">
            <label>バンク</label>
            <div id="bankButtons">
              <button class="bank-btn" data-bank="0">1</button>
              <button class="bank-btn" data-bank="1">2</button>
              <button class="bank-btn" data-bank="2">3</button>
              <button class="bank-btn" data-bank="3">4</button>
              <button class="bank-btn" data-bank="4">5</button>
              <button class="bank-btn" data-bank="5">6</button>
              <button class="bank-btn" data-bank="6">7</button>
              <button class="bank-btn" data-bank="7">8</button>
              <button class="bank-btn" data-bank="8">9</button>
              <button class="bank-btn" data-bank="9">10</button>
            </div>
          </div>
          <div id="toolbar">
            <div class="toolbar-group">
              <label>フォントサイズ</label>
              <input type="range" id="fontSizeSlider" min="10" max="40" value="20" />
              <span id="fontSizeLabel">20px</span>
            </div>
            <div class="toolbar-group">
              <label>高さ</label>
              <input type="range" id="heightSlider" min="100" max="800" value="400" />
              <span id="heightLabel">400px</span>
            </div>
          </div>
          <div id="searchBar">
            <input type="text" id="searchInput" placeholder="検索..." />
            <input type="text" id="replaceInput" placeholder="置換..." />
            <button id="replaceBtn">置換</button>
            <button id="replaceAllBtn">すべて置換</button>
            <span id="matchCount"></span>
          </div>
          <div id="textareaWrapper">
            <textarea id="textarea" spellcheck="false"></textarea>
            <div id="highlightLayer" aria-hidden="true"></div>
          </div>
      </main>
  </div>
</Layout>

<script>
const area = document.getElementById("textarea") as HTMLTextAreaElement
const highlightLayer = document.getElementById("highlightLayer")!
const wrapper = document.getElementById("textareaWrapper")!
const searchInput = document.getElementById("searchInput") as HTMLInputElement
const replaceInput = document.getElementById("replaceInput") as HTMLInputElement
const replaceBtn = document.getElementById("replaceBtn") as HTMLButtonElement
const replaceAllBtn = document.getElementById("replaceAllBtn") as HTMLButtonElement
const matchCount = document.getElementById("matchCount")!
const fontSizeSlider = document.getElementById("fontSizeSlider") as HTMLInputElement
const fontSizeLabel = document.getElementById("fontSizeLabel")!
const heightSlider = document.getElementById("heightSlider") as HTMLInputElement
const heightLabel = document.getElementById("heightLabel")!

const BANK_COUNT = 10
const BANK_PREFIX = "memo_bank_"
const CURRENT_BANK_KEY = "memo_currentBank"
const FONT_SIZE_KEY = "memo_fontSize"
const HEIGHT_KEY = "memo_height"

let currentBank = 0
let undoStack: string[] = []
let redoStack: string[] = []
let ignoreNextInput = false

function escapeHtml(s: string) {
  return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;")
}

function toDisplay(s: string) {
  return escapeHtml(s).replace(/\n/g, "<br>").replace(/ /g, "&nbsp;")
}

function getBankKey(i: number) { return BANK_PREFIX + i }

function save() {
  localStorage.setItem(getBankKey(currentBank), area.value)
  localStorage.setItem(CURRENT_BANK_KEY, String(currentBank))
}

function loadBank(index: number) {
  currentBank = index
  ignoreNextInput = true
  area.value = localStorage.getItem(getBankKey(index)) ?? ""
  localStorage.setItem(CURRENT_BANK_KEY, String(index))
  updateBankButtons()
  const fs = localStorage.getItem(FONT_SIZE_KEY)
  const h = localStorage.getItem(HEIGHT_KEY) || "400"
  if (fs) applyFontSize(Number(fs))
  if (h) applyHeight(Number(h))
  highlightMatches()
  undoStack = []
  redoStack = []
}

function updateBankButtons() {
  document.querySelectorAll(".bank-btn").forEach((btn, i) => {
    btn.classList.toggle("active", i === currentBank)
  })
}

function pushUndo() {
  undoStack.push(area.value)
  if (undoStack.length > 100) undoStack.shift()
  redoStack = []
}

function undo() {
  if (undoStack.length === 0) return
  redoStack.push(area.value)
  ignoreNextInput = true
  area.value = undoStack.pop()!
  save()
  highlightMatches()
}

function redo() {
  if (redoStack.length === 0) return
  undoStack.push(area.value)
  ignoreNextInput = true
  area.value = redoStack.pop()!
  save()
  highlightMatches()
}

let pendingHighlight: number | undefined

function highlightMatches() {
  clearTimeout(pendingHighlight)
  pendingHighlight = window.setTimeout(() => {
    const query = searchInput.value
    const text = area.value
    if (!query) {
      highlightLayer.innerHTML = text ? toDisplay(text) : ""
      matchCount.textContent = ""
      return
    }
    const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")
    const regex = new RegExp(escaped, "gi")
    let html = ""
    let count = 0
    let lastIdx = 0
    let m: RegExpExecArray | null
    while ((m = regex.exec(text)) !== null) {
      html += toDisplay(text.slice(lastIdx, m.index))
      html += `<mark>${toDisplay(text.slice(m.index, m.index + m[0].length))}</mark>`
      lastIdx = regex.lastIndex
      count++
    }
    html += toDisplay(text.slice(lastIdx))
    highlightLayer.innerHTML = html
    matchCount.textContent = count > 0 ? `${count} 件` : ""
  }, 100)
}

function syncScroll() {
  highlightLayer.scrollTop = area.scrollTop
  highlightLayer.scrollLeft = area.scrollLeft
}

function applyFontSize(val: number) {
  area.style.fontSize = val + "px"
  highlightLayer.style.fontSize = val + "px"
  fontSizeLabel.textContent = val + "px"
  fontSizeSlider.value = String(val)
  localStorage.setItem(FONT_SIZE_KEY, String(val))
}

function applyHeight(val: number) {
  wrapper.style.height = val + "px"
  heightLabel.textContent = val + "px"
  heightSlider.value = String(val)
  localStorage.setItem(HEIGHT_KEY, String(val))
}

area.addEventListener("input", () => {
  if (ignoreNextInput) { ignoreNextInput = false; return }
  pushUndo()
  save()
  highlightMatches()
})

area.addEventListener("scroll", syncScroll)

area.addEventListener("keydown", (e) => {
  if (e.ctrlKey && e.key === "z") {
    e.preventDefault()
    undo()
  }
  if (e.ctrlKey && (e.key === "y" || (e.key === "Z" && e.shiftKey))) {
    e.preventDefault()
    redo()
  }
})

searchInput.addEventListener("input", highlightMatches)

replaceBtn.addEventListener("click", () => {
  const query = searchInput.value
  const replacement = replaceInput.value
  if (!query) return
  pushUndo()
  const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")
  const regex = new RegExp(escaped, "i")
  const newVal = area.value.replace(regex, replacement)
  if (newVal !== area.value) {
    ignoreNextInput = true
    area.value = newVal
    save()
    highlightMatches()
    const start = area.value.indexOf(replacement, area.selectionStart)
    if (start !== -1) area.setSelectionRange(start, start + replacement.length)
    area.focus()
  }
})

replaceAllBtn.addEventListener("click", () => {
  const query = searchInput.value
  const replacement = replaceInput.value
  if (!query) return
  pushUndo()
  const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")
  const regex = new RegExp(escaped, "gi")
  ignoreNextInput = true
  area.value = area.value.replace(regex, replacement)
  save()
  highlightMatches()
})

fontSizeSlider.addEventListener("input", () => applyFontSize(Number(fontSizeSlider.value)))
heightSlider.addEventListener("input", () => applyHeight(Number(heightSlider.value)))

document.querySelectorAll(".bank-btn").forEach((btn) => {
  btn.addEventListener("click", () => {
    const bank = Number((btn as HTMLElement).dataset.bank)
    if (bank === currentBank) return
    save()
    loadBank(bank)
  })
})

window.onload = () => {
  const savedBank = Number(localStorage.getItem(CURRENT_BANK_KEY)) || 0
  loadBank(savedBank)
}
</script>

<style is:global>
    #bankBar {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 8px;
      align-items: center;
    }
    #bankButtons {
      display: flex;
      gap: 4px;
    }
    .bank-btn {
      width: 32px;
      height: 32px;
      border: 1px solid #888;
      border-radius: 4px;
      background: #fff;
      cursor: pointer;
      font-size: 13px;
      transition: background .15s, color .15s;
    }
    .bank-btn.active {
      background: #007aff;
      color: #fff;
      border-color: #007aff;
    }
    #toolbar {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
      margin-bottom: 8px;
      align-items: center;
    }
    .toolbar-group {
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .toolbar-group input[type="range"] {
      width: 100px;
    }
    #searchBar {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-bottom: 8px;
      align-items: center;
    }
    #textareaWrapper {
      position: relative;
      overflow: hidden;
    }
    #textarea, #highlightLayer {
      font: 20px monospace;
      line-height: 1.5;
      padding: 8px;
      margin: 0;
      width: 100%;
      height: 100%;
      box-sizing: border-box;
      white-space: pre-wrap;
      word-wrap: break-word;
      overflow-wrap: break-word;
    }
    #textarea {
      position: relative;
      z-index: 2;
      caret-color: auto;
      border: none;
      outline: none;
      resize: none;
      display: block;
      overflow: auto;
    }
    #highlightLayer {
      position: absolute;
      top: 0;
      left: 0;
      z-index: 1;
      pointer-events: none;
      overflow: hidden;
      color: transparent;
    }
    #highlightLayer mark {
      background: Highlight;
      color: transparent;
    }
    @media (orientation: landscape) {
      .nue { width: 90vw; margin: 0 auto; }
    }
</style>
