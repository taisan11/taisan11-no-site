---
import Layout from "../../layouts/layout.astro";
import A from "../../components/A.astro";
---

<Layout title="taisan11のサイト">
    <div class="nue">
      <A href="/tools">← 戻る</A><br/>
      <div class="c">
          <h2>RDAP取得</h2>
          <input type="text" placeholder="Domain" id="domain">
          <button id="search">検索</button>
          <div id="result"></div>
      </div>
  </div>
</Layout>

<script>
const domainDOM = document.getElementById("domain") as HTMLInputElement
const search = document.getElementById("search") as HTMLButtonElement
const result = document.getElementById("result") as HTMLDivElement

function escapeHtml(str: string): string {
  return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;")
}

function buildTable(data: Record<string, string>): string {
  return `<table class="rdap-table"><tbody>${Object.entries(data).map(([k, v]) =>
    `<tr><th>${escapeHtml(k)}</th><td>${escapeHtml(v)}</td></tr>`
  ).join("")}</tbody></table>`
}

function getVcardValue(vcard: any, field: string): string {
  return vcard?.[1]?.find((item: any) => item[0] === field)?.[3] ?? ""
}

function extractEvents(events: any[] | undefined): string {
  if (!events || events.length === 0) return "なし"
  return events.map((ev: any) => `${ev.eventAction}: ${ev.eventDate}`).join("; ")
}

function extractData(obj: any): Record<string, string> {
  const nameservers = (obj.nameservers ?? []).map((ns: any) => ns.ldhName).join(", ")
  const entities = (obj.entities ?? []).map((e: any) => {
    const roles = (e.roles ?? []).join("/")
    const vcard = e.vcardArray
    const fn = getVcardValue(vcard, "fn")
    const org = getVcardValue(vcard, "org")
    const email = getVcardValue(vcard, "email")
    const name = fn || e.handle || ""
    const extra = [org, email].filter(Boolean).join(" / ")
    return `${roles}: ${name}${extra ? ` (${extra})` : ""}`
  }).join("; ")

  const secureDNS = obj.secureDNS
  const dnssecStr = secureDNS?.delegationSigned
    ? `署名あり (algorithm=${secureDNS.algorithm ?? "?"}, digestType=${secureDNS.digestType ?? "?"})`
    : secureDNS === null ? "なし" : "なし"

  return {
    "Domain": obj.ldhName ?? "",
    "Handle": obj.handle ?? "",
    "Status": (obj.status ?? []).join(", "),
    "Whois Server": obj.port43 ?? "なし",
    "登録日": obj.registrationDate ?? "",
    "有効期限": obj.expirationDate ?? "",
    "更新日": obj.lastChangedDate ?? "",
    "DNSSEC": dnssecStr,
    "ネームサーバー": nameservers || "なし",
    "エンティティ": entities || "なし",
    "イベント": extractEvents(obj.events),
    "オブジェクトタイプ": obj.objectClassName ?? "",
  }
}

search.onclick = async () => {
  const domain = domainDOM.value.trim()
  if (!domain) {
    result.innerHTML = "<h3 class=\"error\">Domainをexample.comみたいな感じで入れてね</h3>"
    return
  }
  result.innerHTML = "<p>取得中...</p>"
  try {
    const res = await fetch(`https://rdap.org/domain/${domain}`)
    if (!res.ok) throw new Error(`HTTP ${res.status}`)
    const data = await res.json()
    const tableHtml = buildTable(extractData(data))
    const rawJson = escapeHtml(JSON.stringify(data, null, 2))
    result.innerHTML = tableHtml + `<details class="raw-json"><summary>生のJSONを表示</summary><pre>${rawJson}</pre></details>`
  } catch (e) {
    result.innerHTML = `<h3 class="error">取得に失敗しました: ${escapeHtml((e as Error).message)}</h3>`
  }
}
</script>

<style is:global>
    .nue {}
    .error {
        color:red;
    }
    .rdap-table {
        margin: 1em auto;
        border-collapse: collapse;
        text-align: left;
    }
    .rdap-table th, .rdap-table td {
        border: 1px solid #888;
        padding: 4px 10px;
    }
    .rdap-table th {
        background: #f0f0f0;
        white-space: nowrap;
    }
    .c {
        text-align: center;
    }
    .raw-json {
        margin: 1em auto;
        max-width: 100%;
    }
    .raw-json summary {
        cursor: pointer;
        font-weight: bold;
        text-align: center;
        padding: 4px;
        user-select: none;
    }
    .raw-json pre {
        background: #f5f5f5;
        border: 1px solid #ccc;
        border-radius: 4px;
        padding: 8px;
        font-size: 0.8em;
        overflow-x: auto;
        text-align: left;
        max-height: 400px;
        overflow-y: auto;
    }
    @media (orientation: landscape) {
        .nue {
            width: 50vw;
            margin: 0 auto;
        }
    }
</style>
